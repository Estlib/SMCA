<Window x:Class="SMCA.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SMCA"
        mc:Ignorable="d"
        SizeToContent="WidthAndHeight"
        ResizeMode="CanMinimize"
        Title="MainWindow" Icon="/SMCA.PNG">
    <Grid Width="800" Height="900">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="131*"/>
            <ColumnDefinition Width="29*"/>
        </Grid.ColumnDefinitions>
        <TabControl Margin="0,0,0,71" Grid.ColumnSpan="2">
            <TabItem Header="Main">
                <Grid Background="#FFE5E5E5">
                    <GroupBox Header="API Keys" Margin="10,10,402,619">
                        <Grid>
                            <Label Content="Twitter" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="69"/>
                            <Label Content="Bluesky" HorizontalAlignment="Left" Margin="10,36,0,0" VerticalAlignment="Top" Width="69"/>
                            <Label Content="Instagram" HorizontalAlignment="Left" Margin="10,62,0,0" VerticalAlignment="Top" Width="69"/>
                            <Label Content="Threads" HorizontalAlignment="Left" Margin="10,88,0,0" VerticalAlignment="Top" Width="69"/>
                            <Label Content="Reddit" HorizontalAlignment="Left" Margin="10,114,0,0" VerticalAlignment="Top" Width="69"/>
                            <Label Content="X-UNSET" HorizontalAlignment="Left" Margin="84,10,0,0" VerticalAlignment="Top" Width="69"/>
                            <Label Content="B-UNSET" HorizontalAlignment="Left" Margin="84,36,0,0" VerticalAlignment="Top" Width="69"/>
                            <Label Content="I-UNSET" HorizontalAlignment="Left" Margin="84,62,0,0" VerticalAlignment="Top" Width="69"/>
                            <Label Content="T-UNSET" HorizontalAlignment="Left" Margin="84,88,0,0" VerticalAlignment="Top" Width="69"/>
                            <Label Content="R-UNSET" HorizontalAlignment="Left" Margin="84,114,0,0" VerticalAlignment="Top" Width="69"/>
                            <Button Content="Add Key" HorizontalAlignment="Left" Margin="258,13,0,0" VerticalAlignment="Top" Width="102"/>
                            <Button Content="Add Key" HorizontalAlignment="Left" Margin="258,39,0,0" VerticalAlignment="Top" Width="102"/>
                            <Button Content="Add Key" HorizontalAlignment="Left" Margin="258,65,0,0" VerticalAlignment="Top" Width="102"/>
                            <Button Content="Add Key" HorizontalAlignment="Left" Margin="258,91,0,0" VerticalAlignment="Top" Width="102"/>
                            <Button Content="Add Key" HorizontalAlignment="Left" Margin="258,117,0,0" VerticalAlignment="Top" Width="102"/>
                        </Grid>
                    </GroupBox>
                    <Grid>

                    </Grid>
                    <GroupBox Header="Twitch API" Margin="402,10,10,727">
                        <Grid>
                            <Label Content="Twitch" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="69"/>
                            <Label Content="W-UNSET" HorizontalAlignment="Left" Margin="79,10,0,0" VerticalAlignment="Top" Width="69"/>
                            <Button Content="Add Key" HorizontalAlignment="Left" Margin="258,13,0,0" VerticalAlignment="Top" Width="102"/>
                        </Grid>
                    </GroupBox>
                    <GroupBox Header="Twitch Login" Margin="402,79,10,619">
                        <Grid>
                            <Button Content="Log in" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="86"/>
                            <Label Content="Label" HorizontalAlignment="Left" Margin="116,7,0,0" VerticalAlignment="Top" Width="244"/>
                        </Grid>
                    </GroupBox>
                    <GroupBox Header="Platform Logins" Margin="10,187,10,10">
                        <Grid>
                            <GroupBox Header="Twitter" Margin="10,10,10,475">
                                <Grid>
                                    <Border BorderBrush="Black" BorderThickness="1" Margin="0,0,657,0">
                                        <Image HorizontalAlignment="Left" Height="71" VerticalAlignment="Top" Width="71"/>
                                    </Border>
                                    <Button Content="Log in" HorizontalAlignment="Left" VerticalAlignment="Top" Width="86" Margin="634,43,0,0"/>
                                    <Label Content="Username" HorizontalAlignment="Left" Margin="78,0,0,0" VerticalAlignment="Top"/>
                                </Grid>
                            </GroupBox>
                            <GroupBox Header="Bluesky" Margin="10,116,10,369">
                                <Grid>
                                    <Border BorderBrush="Black" BorderThickness="1" Margin="0,0,657,0">
                                        <Image HorizontalAlignment="Left" Height="71" VerticalAlignment="Top" Width="71"/>
                                    </Border>
                                    <Button Content="Log in" HorizontalAlignment="Left" VerticalAlignment="Top" Width="86" Margin="634,43,0,0"/>
                                    <Label Content="Username" HorizontalAlignment="Left" Margin="78,0,0,0" VerticalAlignment="Top"/>

                                </Grid>
                            </GroupBox>
                            <GroupBox Header="Instagram" Margin="10,222,10,263">
                                <Grid>
                                    <Border BorderBrush="Black" BorderThickness="1" Margin="0,0,657,0">
                                        <Image HorizontalAlignment="Left" Height="71" VerticalAlignment="Top" Width="71"/>
                                    </Border>
                                    <Button Content="Log in" HorizontalAlignment="Left" VerticalAlignment="Top" Width="86" Margin="634,43,0,0"/>
                                    <Label Content="Username" HorizontalAlignment="Left" Margin="78,0,0,0" VerticalAlignment="Top"/>

                                </Grid>
                            </GroupBox>
                            <GroupBox Header="Threads" Margin="10,328,10,157">
                                <Grid>
                                    <Border BorderBrush="Black" BorderThickness="1" Margin="0,0,657,0">
                                        <Image HorizontalAlignment="Left" Height="71" VerticalAlignment="Top" Width="71"/>
                                    </Border>
                                    <Button Content="Log in" HorizontalAlignment="Left" VerticalAlignment="Top" Width="86" Margin="634,43,0,0"/>
                                    <Label Content="Username" HorizontalAlignment="Left" Margin="78,0,0,0" VerticalAlignment="Top"/>

                                </Grid>
                            </GroupBox>
                            <GroupBox Header="Reddit" Margin="10,434,10,51">
                                <Grid>
                                    <Border BorderBrush="Black" BorderThickness="1" Margin="0,0,657,0">
                                        <Image HorizontalAlignment="Left" Height="71" VerticalAlignment="Top" Width="71"/>
                                    </Border>
                                    <Button Content="Log in" HorizontalAlignment="Left" VerticalAlignment="Top" Width="86" Margin="634,43,0,0"/>
                                    <Label Content="Username" HorizontalAlignment="Left" Margin="78,0,0,0" VerticalAlignment="Top"/>

                                </Grid>
                            </GroupBox>
                            <Button Content="Log out all" HorizontalAlignment="Left" VerticalAlignment="Top" Width="86" Margin="666,551,0,0"/>
                        </Grid>
                    </GroupBox>
                    <Grid/>
                </Grid>
            </TabItem>
            <TabItem Header="Postmaker">
                <Grid>
                    <GroupBox Header="Post Scheduling Data" Margin="10,0,0,626">
                        <Grid Margin="0,0,677,0">
                            <GroupBox Header="Where" Margin="0,0,-10,0">
                                <Grid>
                                    <CheckBox Content="Twitter" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top"/>
                                    <CheckBox Content="BlueSky" HorizontalAlignment="Left" Margin="10,70,0,0" VerticalAlignment="Top"/>
                                    <CheckBox Content="Threads" HorizontalAlignment="Left" Margin="10,90,0,0" VerticalAlignment="Top"/>
                                    <CheckBox Content="Reddit" HorizontalAlignment="Left" Margin="10,50,0,0" VerticalAlignment="Top"/>
                                    <CheckBox Content="Instagram" HorizontalAlignment="Center" Margin="0,30,0,0" VerticalAlignment="Top"/>
                                </Grid>
                            </GroupBox>
                            <GroupBox Header="When" Margin="110,0,-234,0">
                                <Grid Margin="0,0,-2,0">
                                    <Label Content="Date" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.5,0.542"/>
                                    <DatePicker HorizontalAlignment="Center" Margin="0,36,0,0" VerticalAlignment="Top" SelectedDateFormat="Short" Width="187"/>
                                    <Label Content="Time" HorizontalAlignment="Left" Margin="10,65,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.5,0.542"/>
                                    <TextBox HorizontalAlignment="Left" Margin="61,69,0,0" TextWrapping="Wrap" Text="00:00" VerticalAlignment="Top" Width="136" AutomationProperties.HelpText="00:00"/>
                                </Grid>
                            </GroupBox>
                            <GroupBox Header="Program settings" Margin="334,0,-672,0">
                                <Grid HorizontalAlignment="Left" Width="433">
                                    <CheckBox Content="Notify me when this post goes live with a " HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top"/>
                                    <RadioButton Content="Window" HorizontalAlignment="Left" Margin="257,10,0,0" VerticalAlignment="Top"/>
                                    <RadioButton Content="or a Balloon" HorizontalAlignment="Left" Margin="325,10,0,0" VerticalAlignment="Top"/>
                                    <CheckBox Content="Log Posting failures" HorizontalAlignment="Left" Margin="10,50,0,0" VerticalAlignment="Top"/>
                                    <CheckBox Content="If notification is window, show buttons to go to the posts" HorizontalAlignment="Left" Margin="10,30,0,0" VerticalAlignment="Top"/>
                                </Grid>
                            </GroupBox>

                        </Grid>
                    </GroupBox>
                    <GroupBox Header="GroupBox" Margin="10,180,10,96"/>
                </Grid>
            </TabItem>
            <TabItem Header="Calendar">
                <Grid Background="#FFE5E5E5"/>
            </TabItem>
            <TabItem Header="Posts Scheduled">
                <Grid Background="#FFE5E5E5"/>
            </TabItem>
            <TabItem Header="Posts Automated">
                <Grid Background="#FFE5E5E5"/>
            </TabItem>
            <TabItem Header="Timeline">
                <Grid Background="#FFE5E5E5"/>
            </TabItem>
            <TabItem Header="Settings">
                <Grid Background="#FFE5E5E5">
                    <Grid>
                        <GroupBox Header="Program settings" Margin="10,10,10,653">
                            <Grid>
                                <CheckBox Content="Unset" HorizontalAlignment="Left" Margin="253,10,0,0" VerticalAlignment="Top"/>
                                <Label Content="Minimize hides window in tray" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" Width="238"/>
                                <CheckBox Content="Unset" HorizontalAlignment="Left" Margin="253,36,0,0" VerticalAlignment="Top"/>
                                <Label Content="Program is silent while in tray" HorizontalAlignment="Left" Margin="10,31,0,0" VerticalAlignment="Top" Width="238"/>
                                <CheckBox Content="Unset" HorizontalAlignment="Left" Margin="253,62,0,0" VerticalAlignment="Top"/>
                                <Label Content="Action Log is dumped into a text file" HorizontalAlignment="Left" Margin="10,56,0,0" VerticalAlignment="Top" Width="238"/>
                                <TextBox HorizontalAlignment="Left" Margin="16,88,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="170"/>
                                <Button Content="Set" HorizontalAlignment="Left" Margin="191,87,0,0" VerticalAlignment="Top" Width="53"/>
                                <Button Content="Go To" HorizontalAlignment="Left" Margin="249,87,0,0" VerticalAlignment="Top" Width="53"/>
                            </Grid>
                        </GroupBox>
                    </Grid>
                    <GroupBox Header="Post automation settings" Margin="10,150,10,430">
                        <Grid>
                            <CheckBox Content="Unset" HorizontalAlignment="Left" Margin="253,10,0,0" VerticalAlignment="Top"/>
                            <Label Content="Twitch streams are automatically posted" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" Width="238"/>
                            <Label Content="And to:" HorizontalAlignment="Left" Margin="10,31,0,0" VerticalAlignment="Top" Width="55"/>
                            <CheckBox Content="Twitter" HorizontalAlignment="Left" Margin="65,37,0,0" VerticalAlignment="Top"/>
                            <CheckBox Content="Bluesky" HorizontalAlignment="Left" Margin="142,37,0,0" VerticalAlignment="Top"/>
                            <CheckBox Content="Reddit" HorizontalAlignment="Left" Margin="207,37,0,0" VerticalAlignment="Top"/>
                            <CheckBox Content="Instagram" HorizontalAlignment="Left" Margin="65,57,0,0" VerticalAlignment="Top"/>
                            <CheckBox Content="Threads" HorizontalAlignment="Left" Margin="142,57,0,0" VerticalAlignment="Top"/>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>
            <TabItem Header="About/Help">
                <Grid Background="#FFE5E5E5">
                    <Grid>
                        <TextBlock HorizontalAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap" 
                                   VerticalAlignment="Top" Width="774" Height="68"><Run Text="SCMA - Social Content Management Assistant is an application meant to help the beginner content creator manage all the usual social apps. This app however is &quot;BYOK&quot; - Bring Your Own Key. What this means is that the user needs to register their own developer accounts with the various API providers and get respective authentication credentials from each platform they wish to use"/><Run Language="et-ee" Text=" - just like YTA functions."/><Run Text=" This needs some technical knowhow and is linked somewhere in the docs of this app."/><Run Language="et-ee" Text="  For that please see the readme on github."/></TextBlock>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
        <Grid HorizontalAlignment="Left" Height="51" Margin="10,0,0,10" VerticalAlignment="Bottom" Width="780" Background="Black" Grid.ColumnSpan="2">
            <Button Content="Button" HorizontalAlignment="Left" VerticalAlignment="Center" Height="35" Width="35" Margin="10,0,0,0"/>
        </Grid>

    </Grid>
</Window>
